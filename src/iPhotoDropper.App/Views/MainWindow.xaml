<Window
    x:Class="iPhotoDropper.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        x:Name="Root"
        MinWidth="980"
        MinHeight="680"
        Background="#F5F5F7">
        <Grid.Resources>
            <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F5F5F7" />
            <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#EDEDF1" />
            <SolidColorBrush x:Key="HairlineBrush" Color="#D9D9DE" />
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1D1D1F" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#6E6E73" />
            <SolidColorBrush x:Key="AccentBrush" Color="#007AFF" />

            <Style x:Key="ToolbarButtonStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="Padding" Value="13,6" />
                <Setter Property="CornerRadius" Value="7" />
                <Setter Property="Background" Value="#F3F3F6" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="BorderBrush" Value="#D6D6DC" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            </Style>

            <Style x:Key="PaneTextBoxStyle" TargetType="TextBox">
                <Setter Property="AcceptsReturn" Value="True" />
                <Setter Property="Background" Value="#FBFBFD" />
                <Setter Property="BorderBrush" Value="#DADAE0" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="7" />
                <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="IsReadOnly" Value="True" />
                <Setter Property="Padding" Value="10" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="58" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Background="#FCFCFD"
            BorderBrush="{StaticResource HairlineBrush}"
            BorderThickness="0,0,0,1">
            <Grid Padding="18,0" ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                    <Border Width="12" Height="12" Background="#FF605C" CornerRadius="6" />
                    <Border Width="12" Height="12" Background="#FFBD44" CornerRadius="6" />
                    <Border Width="12" Height="12" Background="#00CA4E" CornerRadius="6" />
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                    <TextBlock
                        Text="iPhotoDropper"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock
                        Text="Импорт фото и видео с iPhone"
                        FontSize="12"
                        Foreground="{StaticResource SecondaryTextBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button
                        x:Name="RefreshButton"
                        Content="Обновить"
                        Click="OnRefreshClick"
                        Style="{StaticResource ToolbarButtonStyle}" />
                    <Button
                        x:Name="BrowseButton"
                        Content="Папка..."
                        Click="OnBrowseDestination"
                        Style="{StaticResource ToolbarButtonStyle}" />
                    <Button
                        x:Name="ImportButton"
                        Content="Импорт"
                        Click="OnImportClick"
                        Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,1,0">
                <Grid Padding="16,18" RowSpacing="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            Text="Медиатека"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource SecondaryTextBrush}" />
                        <Border
                            Padding="10,8"
                            Background="#FFFFFF"
                            BorderBrush="#D8D8DE"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="▣" FontSize="17" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Spacing="1">
                                    <TextBlock Text="iPhone" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                                    <TextBlock x:Name="DeviceStatusText" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Spacing="10">
                        <TextBlock
                            Text="Фильтры импорта"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource SecondaryTextBrush}" />
                        <CheckBox x:Name="PhotosCheckBox" Content="Фото" Checked="OnFilterChanged" Unchecked="OnFilterChanged" />
                        <CheckBox x:Name="VideosCheckBox" Content="Видео" Checked="OnFilterChanged" Unchecked="OnFilterChanged" />
                        <CheckBox x:Name="CopyOnlyNewCheckBox" Content="Только новые" Checked="OnFilterChanged" Unchecked="OnFilterChanged" />
                        <CheckBox x:Name="OrganizeByDateCheckBox" Content="Папки по датам" Checked="OnFilterChanged" Unchecked="OnFilterChanged" />
                        <StackPanel Spacing="5">
                            <TextBlock Text="Макс. размер, MB" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBox
                                x:Name="MaxSizeTextBox"
                                PlaceholderText="без лимита"
                                TextChanged="OnMaxSizeTextChanged"
                                Background="#FFFFFF"
                                BorderBrush="#D8D8DE"
                                CornerRadius="7"
                                Padding="8,5" />
                        </StackPanel>
                    </StackPanel>

                    <Border
                        Grid.Row="2"
                        Padding="12"
                        Background="#FFFFFF"
                        BorderBrush="#D8D8DE"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Text="Устройство"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryTextBrush}" />
                            <TextBlock
                                x:Name="DeviceDetailsTextBlock"
                                Grid.Row="1"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                FontSize="12"
                                TextWrapping="Wrap" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="3" Spacing="8">
                        <Button
                            x:Name="ScanButton"
                            Content="Показать медиа"
                            Click="OnScanClick"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource PrimaryButtonStyle}" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button
                                x:Name="PauseButton"
                                Content="Пауза"
                                Click="OnPauseClick"
                                Style="{StaticResource ToolbarButtonStyle}" />
                            <Button
                                x:Name="ResumeButton"
                                Grid.Column="1"
                                Content="Продолжить"
                                Click="OnResumeClick"
                                Style="{StaticResource ToolbarButtonStyle}" />
                        </Grid>
                        <Button
                            x:Name="CancelButton"
                            Content="Отмена"
                            Click="OnCancelClick"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource ToolbarButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Padding="20" RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="172" />
                </Grid.RowDefinitions>

                <Border
                    Padding="14,12"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock
                                    x:Name="CurrentFileTextBlock"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    x:Name="ProgressTextBlock"
                                    FontSize="12"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock
                                x:Name="ProgressBarTextBlock"
                                Grid.Column="1"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                VerticalAlignment="Top" />
                        </Grid>

                        <Grid Grid.Row="1" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="5">
                                <TextBlock x:Name="OverallProgressLabelTextBlock" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock
                                    x:Name="OverallProgressBarTextBlock"
                                    FontFamily="Cascadia Mono, Consolas"
                                    FontSize="13"
                                    Foreground="{StaticResource AccentBrush}"
                                    TextWrapping="NoWrap" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="5">
                                <TextBlock x:Name="CurrentFileProgressLabelTextBlock" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock
                                    x:Name="CurrentFileProgressBarTextBlock"
                                    FontFamily="Cascadia Mono, Consolas"
                                    FontSize="13"
                                    Foreground="{StaticResource AccentBrush}"
                                    TextWrapping="NoWrap" />
                            </StackPanel>
                        </Grid>

                        <TextBlock
                            x:Name="CurrentFileProgressDetailsTextBlock"
                            Grid.Row="2"
                            FontSize="12"
                            Foreground="{StaticResource SecondaryTextBrush}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="330" />
                        <ColumnDefinition Width="*" MinWidth="330" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="На этом iPhone" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                                    <TextBlock x:Name="SelectionSummaryTextBlock" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    Content="Обновить"
                                    Click="OnScanClick"
                                    Style="{StaticResource ToolbarButtonStyle}" />
                            </Grid>

                            <TextBlock
                                Grid.Row="1"
                                Text="Список прокручивается вертикально и горизонтально, чтобы длинные имена и пути не ломали окно."
                                FontSize="12"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                TextWrapping="Wrap" />

                            <TextBox
                                x:Name="MediaFilesTextBox"
                                Grid.Row="2"
                                MinHeight="240"
                                Style="{StaticResource PaneTextBoxStyle}" />
                        </Grid>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Куда копируем" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                                <TextBlock
                                    x:Name="DestinationTextBlock"
                                    FontSize="12"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap" />
                            </StackPanel>

                            <TextBlock
                                x:Name="LastReportTextBlock"
                                Grid.Row="1"
                                Foreground="{StaticResource PrimaryTextBrush}"
                                FontSize="12"
                                MinHeight="34"
                                TextWrapping="Wrap" />

                            <TextBox
                                x:Name="DestinationFilesTextBox"
                                Grid.Row="2"
                                MinHeight="240"
                                Style="{StaticResource PaneTextBoxStyle}" />
                        </Grid>
                    </Border>
                </Grid>

                <Border
                    Grid.Row="2"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Журнал" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                        <TextBox
                            x:Name="ScanLogTextBox"
                            Grid.Row="1"
                            MinHeight="96"
                            Style="{StaticResource PaneTextBoxStyle}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
